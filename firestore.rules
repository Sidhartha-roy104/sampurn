// firestore.rules
// Paste this in: Firebase Console → Firestore → Rules → Publish
//
// Users can only read/write their own habits.
// Firebase Auth UID is used as the userId field.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /habits/{habitId} {
      // Only the authenticated user who owns the habit can access it
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.userId;
      // Allow creating new habits (resource doesn't exist yet)
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;
    }
  }
}
